# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Use the DIRECT connection string for migrations (port 5432, not pooler):
# Project Settings → Database → Connection string → URI mode
DATABASE_URL="postgresql://user:password@localhost:5432/ongrid"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Campus WiFi subnet validation (CIDR format) ──────────────────────────────
COLLEGE_WIFI_SUBNET="10.0.0.0/8"

# ─── WebAuthn / Passkey settings ──────────────────────────────────────────────
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="OnGrid Attendance"
WEBAUTHN_ORIGIN="http://localhost:3000"

